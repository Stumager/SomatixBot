# Copy this file to `.env` and fill with local values.
# Never commit `.env` or real production secrets.

# Django
DJANGO_SECRET_KEY=change-me-use-a-long-random-value
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database credentials used by docker-compose and Django.
DB_HOST=db
DB_NAME=tasker_db
DB_USER=postgres_user
DB_PASSWORD=change-me-local-password
DB_PORT=5432
# Optional for local checks/tests without PostgreSQL.
DJANGO_USE_SQLITE=False

# Telegram bot token.
BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# Frontend
VITE_API_BASE_URL=/api/
